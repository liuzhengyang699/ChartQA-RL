{
  "model": {
    "model_id": "Qwen/Qwen3-VL-4B-Instruct",
    "torch_dtype": "bfloat16"
  },
  "dataset": {
    "source": "swift/ChartQA",
    "subset": -1,
    "seed": 42,
    "test_size": 0.1,
    "eval_size": 0.1
  },
  "sft": {
    "num_train_epochs": 1,
    "learning_rate": 0.0002,
    "weight_decay": 0.0,
    "warmup_ratio": 0.03,
    "per_device_train_batch_size": 1,
    "per_device_eval_batch_size": 1,
    "gradient_accumulation_steps": 16,
    "max_length": 1024,
    "logging_steps": 10,
    "eval_steps": 200,
    "save_steps": 200,
    "save_total_limit": 3,
    "lora_r": 8,
    "lora_alpha": 16,
    "lora_dropout": 0.05,
    "lora_target_modules": ["q_proj", "v_proj"],
    "merge_lora": false
  },
  "logging": {
    "report_to": ["swanlab"],
    "run_name": "qwen3vl4b-chartqa-sft",
    "swanlab_project": "chartqa_rl_lora",
    "swanlab_mode": "cloud",
    "swanlab_log_dir": null,
    "swanlab_api_key": null
  },
  "eval": {
    "split": "test",
    "max_samples": -1,
    "max_new_tokens": 32,
    "device": "cuda"
  }
}
